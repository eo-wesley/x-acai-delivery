# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
NODE_ENV=production
PORT=3000

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
ADMIN_SECRET=CHANGE_ME_STRONG_ADMIN_SECRET

# --- Database ---
DATABASE_URL=/data/database.sqlite

# --- CORS ---
CORS_ORIGIN=https://yourdomain.com

# --- Domain (SaaS slug routing) ---
BASE_DOMAIN=acaidedelivery.com.br

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.acaidedelivery.com.br

# --- MercadoPago ---
# Sandbox: https://www.mercadopago.com.br/developers/panel
MERCADOPAGO_TOKEN=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- AI / LLM ---
# Options: gemini | mock
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# --- WhatsApp (optional, leave blank to run in DRY_RUN mode) ---
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PHONE_ID=

# --- Firebase (optional, leave blank to use local SQLite) ---
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
