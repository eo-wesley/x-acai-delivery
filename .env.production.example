# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- App ---
NODE_ENV=production
PORT=3000

# --- Security ---
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
ADMIN_SECRET=CHANGE_ME_STRONG_ADMIN_SECRET

# --- Database ---
# PostgreSQL de staging/produção (Neon recomendado)
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/xacai_staging?sslmode=require&channel_binding=require
# Somente para o primeiro bootstrap do staging limpo: true, executar migrate/seed, depois voltar para false
DB_SEED_MINIMAL=false
# Local apenas:
# SQLITE_PATH=apps/backend/database.sqlite

# --- CORS ---
CORS_ORIGIN=https://yourdomain.com

# --- Domain (SaaS slug routing) ---
BASE_DOMAIN=acaidedelivery.com.br

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.acaidedelivery.com.br

# --- MercadoPago ---
# Sandbox: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_WEBHOOK_URL=https://api.acaidedelivery.com.br/api/webhooks/mercadopago
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- AI / LLM ---
# Options: gemini | mock
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# --- WhatsApp / Evolution API ---
# Options: mock | evolution
WHATSAPP_PROVIDER=evolution
WHATSAPP_BASE_URL=https://evolution.acaidedelivery.com.br
WHATSAPP_INSTANCE=restaurante-acai
WHATSAPP_API_KEY=CHANGE_ME_EVOLUTION_KEY

# --- Firebase (required for staging/prod admin auth) ---
# Preferencial no Render: cole o JSON completo da service account em uma unica variavel
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternativa: preencher o trio abaixo
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
