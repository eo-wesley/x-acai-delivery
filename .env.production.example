# ============================================================
# PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Current public production before custom domain cutover.
# NEVER commit a real .env with secrets.
# ============================================================

# --- App ---
NODE_ENV=production
PORT=3000

# --- Security ---
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET
ADMIN_SECRET=CHANGE_ME_STRONG_ADMIN_SECRET

# --- Database ---
DATABASE_URL=postgresql://user:password@ep-example-pooler.region.aws.neon.tech/xacai_prod?sslmode=require&channel_binding=require
DB_SEED_MINIMAL=false

# --- CORS / Domain ---
CORS_ORIGIN=https://x-acai-delivery.vercel.app
BASE_DOMAIN=app.seudominio.com

# --- Frontend public runtime ---
NEXT_PUBLIC_API_URL=https://x-acai-production-backend.onrender.com
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_FIREBASE_WEB_API_KEY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=xacai-delivery-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=xacai-delivery-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=xacai-delivery-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1077201570871
NEXT_PUBLIC_FIREBASE_APP_ID=1:1077201570871:web:CHANGE_ME

# --- Mercado Pago ---
MP_ACCESS_TOKEN=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
MP_WEBHOOK_URL=https://x-acai-production-backend.onrender.com/api/payments/mercadopago/webhook/mercadopago
MERCADOPAGO_PUBLIC_KEY=APP_USR-XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# --- AI / LLM ---
LLM_PROVIDER=gemini
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-2.0-flash

# --- WhatsApp / Evolution API ---
# Current production default stays in mock until a public Evolution is ready.
WHATSAPP_PROVIDER=mock
WHATSAPP_BASE_URL=https://wa.seudominio.com
WHATSAPP_INSTANCE=restaurante-acai
WHATSAPP_API_KEY=CHANGE_ME_EVOLUTION_KEY

# --- Firebase Admin ---
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
