{
  "name": "xacai-backend",
  "version": "1.0.0",
  "description": "X-Açaí Backend with LLM and WhatsApp integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "seed:demo": "tsx src/seeds/seed-demo-v2.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed:minimal": "tsx src/db/seed-minimal.ts",
    "db:bootstrap:staging": "npm run db:migrate && npm run db:seed:minimal",
    "db:seed": "tsx src/seeds/seed-demo-v2.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "firebase",
    "llm",
    "whatsapp",
    "orders"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@sentry/node": "^10.46.0",
    "@sentry/profiling-node": "^10.46.0",
    "axios": "^1.6.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "firebase-admin": "^12.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "prom-client": "^15.1.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.11.10",
    "@types/uuid": "^10.0.0",
    "@types/winston": "^2.4.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
