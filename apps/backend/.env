# ─── X-Açaí Delivery — .env (local) ─────────────────────────────────────────

# Firebase — Painel: Firebase Console > Configurações > Contas de Serviço
FIREBASE_PROJECT_ID=xacai-delivery-prod
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# LLM / IA
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ─── WhatsApp (Evolution API) ─────────────────────────────────────────────────
# AMBIENTE LOCAL — Evolution rodando em localhost:8080
# Para staging/produção: alterar WHATSAPP_PROVIDER=mock no servidor remoto.
WHATSAPP_PROVIDER=evolution
WHATSAPP_BASE_URL=http://localhost:8080
WHATSAPP_INSTANCE=acai-delivery
WHATSAPP_API_KEY=xacai-secret-api-key-2024

# ─── Performance & Cache ──────────────────────────────────────────────────────
AI_TIMEOUT_MS=20000
AI_MAX_OUTPUT_TOKENS=800
AI_CACHE_TTL_DEFAULT_SEC=120
AI_CACHE_TTL_MENU_SEC=600
AI_CACHE_TTL_INFO_SEC=3600

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ─── Servidor ────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development
