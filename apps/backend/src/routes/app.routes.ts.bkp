router.get('/admin/menu/:id/options', adminAuthMiddleware, async (req, res) => {
    try {
        const db = await (await import('../db/db.client')).getDb();
        const groups = await db.all(`SELECT * FROM option_groups WHERE menu_item_id = ? ORDER BY sort_order ASC`, [req.params.id]);
        const enrichedGroups = await Promise.all(groups.map(async (g) => {
            const options = await db.all(`SELECT * FROM option_items WHERE option_group_id = ? ORDER BY sort_order ASC`, [g.id]);
            return { ...g, options: options.map(o => ({ ...o, available: o.available === 1 })) };
        }));
        res.json(enrichedGroups.map(g => ({ ...g, required: g.required === 1 })));
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

