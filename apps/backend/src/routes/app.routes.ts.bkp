// ---------------------------------------------------------
// ANALYTICS / METRICS ENGINE
// ---------------------------------------------------------

router.get('/admin/metrics', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();

        const todayStart = new Date();
        todayStart.setHours(0, 0, 0, 0);
        const todayISO = todayStart.toISOString().replace('T', ' ').slice(0, 19);

        // Orders today
        const todayOrders = await db.get(
            `SELECT COUNT(*) as count, COALESCE(SUM(total_cents),0) as revenue
             FROM orders WHERE restaurant_id = ? AND created_at >= ?`,
            [tenantId, todayISO]
        );

        // Orders this week
        const weekStart = new Date();
        const day = weekStart.getDay();
        const diff = weekStart.getDate() - day + (day === 0 ? -6 : 1);
        weekStart.setDate(diff);
        weekStart.setHours(0, 0, 0, 0);
        const weekISO = weekStart.toISOString().replace('T', ' ').slice(0, 19);
        const weekOrders = await db.get(
            `SELECT COUNT(*) as count, COALESCE(SUM(total_cents),0) as revenue
             FROM orders WHERE restaurant_id = ? AND created_at >= ?`,
            [tenantId, weekISO]
        );

        // Orders this month
        const monthStart = new Date(); monthStart.setDate(1); monthStart.setHours(0, 0, 0, 0);
        const monthISO = monthStart.toISOString().replace('T', ' ').slice(0, 19);
        const monthOrders = await db.get(
            `SELECT COUNT(*) as count, COALESCE(SUM(total_cents),0) as revenue
             FROM orders WHERE restaurant_id = ? AND created_at >= ?`,
            [tenantId, monthISO]
        );

        // Orders by status
        const byStatus = await db.all(
            `SELECT status, COUNT(*) as count FROM orders WHERE restaurant_id = ? GROUP BY status`,
            [tenantId]
        );

        // Top products (from items JSON — aggregate by menuItemId)
        const allOrders = await db.all(
            `SELECT items FROM orders WHERE restaurant_id = ? AND created_at >= ? AND status != 'cancelled'`,
            [tenantId, monthISO]
        );

        const productCounts: Record<string, { name: string, qty: number }> = {};
        for (const o of allOrders) {
            try {
                const items = JSON.parse(o.items);
                for (const it of items) {
                    const key = it.menuItemId;
                    if (!productCounts[key]) productCounts[key] = { name: it.name || key, qty: 0 };
                    productCounts[key].qty += it.qty || 1;
                }
            } catch { }
        }
        const topProducts = Object.entries(productCounts)
            .sort((a, b) => b[1].qty - a[1].qty)
            .slice(0, 5)
            .map(([id, v]) => ({ menuItemId: id, name: v.name, qty: v.qty }));

        // Avg rating
        const avgRating = await db.get(
            `SELECT AVG(stars) as avg, COUNT(*) as total FROM order_ratings WHERE restaurant_id = ?`,
            [tenantId]
        );

        // Active orders right now
        const activeOrders = await db.get(
            `SELECT COUNT(*) as count FROM orders WHERE restaurant_id = ? AND status IN ('accepted','preparing','delivering')`,
            [tenantId]
        );

        // Ticket médio (last 30 days)
        const avgTicket = await db.get(
            `SELECT AVG(total_cents) as avg FROM orders WHERE restaurant_id = ? AND status != 'cancelled' AND created_at >= ?`,
            [tenantId, monthISO]
        );

        res.json({
            today: { orders: todayOrders.count, revenue_cents: todayOrders.revenue },
            week: { orders: weekOrders.count, revenue_cents: weekOrders.revenue },
            month: { orders: monthOrders.count, revenue_cents: monthOrders.revenue },
            active_orders: activeOrders.count,
            avg_ticket_cents: Math.round(avgTicket.avg || 0),
            orders_by_status: byStatus,
            top_products: topProducts,
            rating: { avg: avgRating.avg ? Math.round(avgRating.avg * 10) / 10 : null, total: avgRating.total },
        });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

