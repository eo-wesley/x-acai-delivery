import { Router } from 'express';
import rateLimit from 'express-rate-limit';
import { z } from 'zod';
import { aiMetrics } from '../ai/metrics/ai.metrics';
import { env } from '../config/env';
import { mercadoPagoService } from '../payments/mercadopago.service';
import { pixPaymentService } from '../payments/pix.service';
import { menuRepo } from '../db/repositories/menu.repo';
import { ordersRepo } from '../db/repositories/orders.repo';
import jwt from 'jsonwebtoken';
import { sendNotification, statusToEvent } from '../notifications/notification.service';
import { resolveTenant } from '../middlewares/tenant.middleware';

// SSE clients registry (admin order stream)
const sseClients = new Map<string, any[]>();
function broadcastOrders(tenantId: string, data: unknown) {
    const clients = sseClients.get(tenantId) || [];
    const msg = `data: ${JSON.stringify(data)}\n\n`;
    clients.forEach(res => { try { res.write(msg); } catch { } });
}

const router = Router();

// Middlewares
const appRateLimiter = rateLimit({
    windowMs: 60 * 1000,
    max: 100, // 100 requests per minute per IP for standard REST
    message: { error: 'Too many requests, please try again later.' },
});

const adminAuthMiddleware = (req: any, res: any, next: any) => {
    const authHeader = req.headers['authorization'];
    const token = authHeader ? authHeader.split('Bearer ')[1] : null;

    process.env.JWT_SECRET = process.env.JWT_SECRET || 'fallback_jwt_secret_123';

    if (!token) {
        return res.status(401).json({ error: 'Token is missing' });
    }

    try {
        const decoded = jwt.verify(token, process.env.JWT_SECRET);
        req.admin = decoded;
        next();
    } catch (err) {
        return res.status(401).json({ error: 'Invalid or expired token' });
    }
};

router.use(appRateLimiter);

