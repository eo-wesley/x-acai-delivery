    }
});

// ---------------------------------------------------------
// ORDER RATINGS
// ---------------------------------------------------------

// Public: Submit rating (after order is completed)
router.post('/orders/:id/rating', async (req, res) => {
    try {
        const { v4: uuidv4 } = await import('uuid');
        const orderId = req.params.id;
        const { stars, comment, customerName } = req.body;

        if (!stars || stars < 1 || stars > 5) return res.status(400).json({ error: 'Stars must be 1–5' });

        const order = await ordersRepo.getOrderById(orderId);
        if (!order) return res.status(404).json({ error: 'Order not found' });
        if ((order as any).status !== 'completed') return res.status(400).json({ error: 'Só é possível avaliar pedidos concluídos' });

        const db = await (await import('../db/db.client')).getDb();
        const id = uuidv4();
        await db.run(
            `INSERT INTO order_ratings (id, order_id, restaurant_id, customer_name, stars, comment)
             VALUES (?, ?, ?, ?, ?, ?)`,
            [id, orderId, (order as any).restaurant_id || 'default_tenant', customerName || null, stars, comment || null]
        );
        res.status(201).json({ success: true, id });
    } catch (e: any) {
        if (e.message?.includes('UNIQUE')) return res.status(409).json({ error: 'Este pedido já foi avaliado' });
        res.status(500).json({ error: e.message });
    }
});

// Public: Get rating for an order
router.get('/orders/:id/rating', async (req, res) => {
    try {
        const db = await (await import('../db/db.client')).getDb();
        const rating = await db.get(`SELECT * FROM order_ratings WHERE order_id = ?`, [req.params.id]);
        if (!rating) return res.status(404).json({ error: 'No rating found' });
        res.json(rating);
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// Admin: List all ratings for tenant
router.get('/admin/ratings', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();
        const ratings = await db.all(
            `SELECT r.*, o.total_cents, o.created_at as order_date
             FROM order_ratings r
             JOIN orders o ON r.order_id = o.id
             WHERE r.restaurant_id = ?
             ORDER BY r.created_at DESC`,
            [tenantId]
        );
        res.json(ratings);
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// ---------------------------------------------------------
// RESTAURANT OPERATIONS ENGINE
// ---------------------------------------------------------

// Public: Get store status (used by customer app to decide if checkout is allowed)
router.get('/:slug/store', async (req, res) => {
    try {
        const tenantId = await resolveTenant(req.params.slug);
        const db = await (await import('../db/db.client')).getDb();
        const r = await db.get(`SELECT store_status, temp_close_reason, opening_hours, timezone,
            prep_time_minutes, delivery_fee_cents, min_order_cents, max_orders_simultaneous, name, description,
            logo_url, banner_url, address, whatsapp FROM restaurants WHERE id = ?`, [tenantId]);
        if (!r) return res.json({ store_status: 'open', name: 'X-Açaí', can_accept_orders: true });

        // Check active orders vs capacity
        let isAtCapacity = false;
        if (r.max_orders_simultaneous > 0) {
            const activeCount = await db.get(
                `SELECT COUNT(*) as cnt FROM orders WHERE restaurant_id = ? AND status IN ('pending_payment','accepted','preparing')`,
                [tenantId]
            );
            isAtCapacity = (activeCount?.cnt || 0) >= r.max_orders_simultaneous;
        }

        res.json({
            ...r,
            opening_hours: r.opening_hours ? JSON.parse(r.opening_hours) : null,
            is_at_capacity: isAtCapacity,
            can_accept_orders: r.store_status === 'open' && !isAtCapacity,
        });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// Admin: Update store status (open/closed/paused + reason)
router.patch('/admin/store', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || req.body.slug || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();

        const allowed = ['open', 'closed', 'paused', 'busy'];
        const { store_status, temp_close_reason } = req.body;

        if (store_status && !allowed.includes(store_status)) {
            return res.status(400).json({ error: `Invalid status. Use: ${allowed.join(', ')}` });
        }

        const updates: string[] = [];
        const values: any[] = [];
        if (store_status) { updates.push('store_status = ?'); values.push(store_status); }
        if (temp_close_reason !== undefined) { updates.push('temp_close_reason = ?'); values.push(temp_close_reason || null); }

        if (updates.length) {
            values.push(tenantId);
            await db.run(`UPDATE restaurants SET ${updates.join(', ')} WHERE id = ?`, values);
        }
        res.json({ success: true });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// Admin: Update restaurant profile (name, hours, fees, prep time, etc.)
router.get('/admin/profile', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();
        const r = await db.get(`SELECT * FROM restaurants WHERE id = ?`, [tenantId]);
        if (!r) return res.status(404).json({ error: 'Restaurant not found' });
        res.json({ ...r, opening_hours: r.opening_hours ? JSON.parse(r.opening_hours) : null });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

router.patch('/admin/profile', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || req.body.slug || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();

        const fields = ['name', 'description', 'phone', 'address', 'whatsapp', 'logo_url', 'banner_url',
            'prep_time_minutes', 'delivery_fee_cents', 'min_order_cents', 'max_orders_simultaneous',
            'timezone', 'opening_hours', 'store_status', 'temp_close_reason'];

        const updates: string[] = [];
        const values: any[] = [];

        for (const f of fields) {
            if (req.body[f] !== undefined) {
                updates.push(`${f} = ?`);
                values.push(f === 'opening_hours' && typeof req.body[f] === 'object'
                    ? JSON.stringify(req.body[f])
                    : req.body[f]);
            }
        }

        if (updates.length === 0) return res.json({ success: true });
        values.push(tenantId);
        await db.run(`UPDATE restaurants SET ${updates.join(', ')} WHERE id = ?`, values);
        res.json({ success: true });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// Admin: Toggle menu item availability (available/out_of_stock/hidden)
router.patch('/admin/menu/:id/availability', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || req.body.slug || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();
        const { available, out_of_stock, hidden } = req.body;

        const updates: string[] = [];
        const values: any[] = [];
        if (available !== undefined) { updates.push('available = ?'); values.push(available ? 1 : 0); }
        if (out_of_stock !== undefined) { updates.push('out_of_stock = ?'); values.push(out_of_stock ? 1 : 0); }
        if (hidden !== undefined) { updates.push('hidden = ?'); values.push(hidden ? 1 : 0); }

        if (updates.length === 0) return res.json({ success: true });
        values.push(req.params.id, tenantId);
        await db.run(`UPDATE menu_items SET ${updates.join(', ')} WHERE id = ? AND restaurant_id = ?`, values);
        res.json({ success: true });
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

