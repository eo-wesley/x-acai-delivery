router.get('/admin/notification-logs', adminAuthMiddleware, async (req, res) => {
    try {
        const db = await (await import('../db/db.client')).getDb();
        const limit = Math.min(parseInt(req.query.limit as string || '50'), 200);
        const orderId = req.query.order_id as string | undefined;

        let query = `SELECT * FROM notification_logs`;
        const params: any[] = [];
        if (orderId) {
            query += ` WHERE order_id = ?`;
            params.push(orderId);
        }
        query += ` ORDER BY created_at DESC LIMIT ?`;
        params.push(limit);

        const logs = await db.all(query, params);
        res.json(logs);
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// Health check for Evolution API connectivity
router.get('/admin/whatsapp/status', adminAuthMiddleware, async (req, res) => {
    const provider = (process.env.WHATSAPP_PROVIDER || 'mock').toLowerCase();
    const baseUrl = process.env.WHATSAPP_BASE_URL;
    const instance = process.env.WHATSAPP_INSTANCE;
    const apiKey = process.env.WHATSAPP_API_KEY;

    if (provider !== 'evolution' || !baseUrl || !instance || !apiKey) {
        return res.json({
            provider,
            configured: false,
            status: 'mock_mode',
            message: 'Evolution API not configured — using mock provider',
        });
    }

    try {
        const url = `${baseUrl.replace(/\/$/, '')}/instance/fetchInstances`;
        const checkRes = await fetch(url, {
            headers: { apikey: apiKey },
            signal: AbortSignal.timeout(5000),
        });
        if (checkRes.ok) {
            const data = (await checkRes.json()) as any;
            const inst = Array.isArray(data) ? data.find((i: any) => i.name === instance) : null;
            res.json({
                provider,
                configured: true,
                status: inst?.connectionStatus || 'unknown',
                instance,
                connected: inst?.connectionStatus === 'open',
            });
        } else {
            res.json({ provider, configured: true, status: 'api_error', code: checkRes.status });
        }
    } catch (e: any) {
        res.json({ provider, configured: true, status: 'unreachable', error: e.message });
    }
});


