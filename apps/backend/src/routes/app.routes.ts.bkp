router.put('/admin/menu/:id', adminAuthMiddleware, async (req, res) => {
    try {
        const success = await menuRepo.updateMenuItem(req.params.id, req.body);
        if (success) res.json({ success: true });
        else res.status(404).json({ error: 'Menu item not found' });
