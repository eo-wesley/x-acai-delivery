router.post('/admin/login', async (req, res) => {
    const { secret } = req.body;
    process.env.ADMIN_SECRET = process.env.ADMIN_SECRET || 'admin_secret_123';
    process.env.JWT_SECRET = process.env.JWT_SECRET || 'fallback_jwt_secret_123';

    if (secret === process.env.ADMIN_SECRET) {
        const token = jwt.sign({ role: 'admin' }, process.env.JWT_SECRET, { expiresIn: '8h' });
        return res.json({ success: true, token });
    } else {
        return res.status(401).json({ error: 'Invalid credentials' });
    }
});

router.get('/admin/orders', adminAuthMiddleware, async (req, res) => {
    try {
        const slug = req.query.slug as string || 'default';
        const tenantId = await resolveTenant(slug);
        const db = await (await import('../db/db.client')).getDb();
        const orders = await db.all(
            `SELECT o.*, cu.name as customer_name, cu.phone as customer_phone, o.address_text as customer_address
             FROM orders o
             LEFT JOIN customers cu ON o.customer_id = cu.id AND cu.restaurant_id = o.restaurant_id
             WHERE o.restaurant_id = ?
             ORDER BY o.created_at DESC
             LIMIT 200`,
            [tenantId]
        );
        const mapped = orders.map(o => ({ ...o, items: JSON.parse(o.items || '[]') }));
        res.json(mapped);
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

// SSE: real-time orders stream for admin
router.get('/admin/orders/stream', adminAuthMiddleware, async (req: any, res: any) => {
    const slug = req.query.slug as string || 'default';
    let tenantId: string;
    try { tenantId = await resolveTenant(slug); } catch { tenantId = 'default_tenant'; }

    res.setHeader('Content-Type', 'text/event-stream');
    res.setHeader('Cache-Control', 'no-cache');
    res.setHeader('Connection', 'keep-alive');
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.flushHeaders();

    // Register client
    const clients = sseClients.get(tenantId) || [];
    clients.push(res);
    sseClients.set(tenantId, clients);

    // Send initial ping
    res.write(`data: {"type":"connected","tenant":"${tenantId}"}\n\n`);

    // Cleanup on disconnect
    req.on('close', () => {
        const updated = (sseClients.get(tenantId) || []).filter(c => c !== res);
        sseClients.set(tenantId, updated);
    });
});

router.put('/admin/orders/:id/status', adminAuthMiddleware, async (req, res) => {
    try {
        const orderId = req.params.id;
        const { status } = req.body;
        if (!orderId || !status) return res.status(400).json({ error: 'Missing orderId or status' });

        const success = await ordersRepo.updateOrderStatus(orderId, status);
        if (success) {
            // Fetch order for notification + SSE broadcast
            const order = await ordersRepo.getOrderById(orderId);

            // Fire WhatsApp notification (never blocks)
            const event = statusToEvent(status);
            if (event && order) {
                sendNotification({
                    orderId,
                    event,
                    customerPhone: (order as any).customer_phone,
                    customerName: (order as any).customer_name,
                    totalCents: (order as any).total_cents,
                    extra: { items: (order as any).items }
                });
            }

            // Broadcast to SSE clients
            if (order) {
                const tenantId = (order as any).restaurant_id || 'default_tenant';
                broadcastOrders(tenantId, { type: 'status_updated', orderId, status });
            }

            res.json({ success: true, status });
        } else {
            res.status(400).json({ error: 'Failed to update status' });
        }
    } catch (e: any) {
        res.status(500).json({ error: e.message });
    }
});

