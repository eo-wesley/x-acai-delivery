# Infraestrutura Geral
PORT=3000
NODE_ENV=development

# Banco de Dados
# Local: deixe DATABASE_URL vazio e use SQLite
SQLITE_PATH=apps/backend/database.sqlite
DATABASE_URL=
# Exemplo de staging/produção:
# DATABASE_URL=postgresql://user:password@host:5432/xacai_staging?sslmode=require&channel_binding=require
DB_SEED_MINIMAL=false

# Cache & Filas
REDIS_URL=redis://user:password@host:port

# Segurança
JWT_SECRET=sua_chave_secreta_longa_aqui
ENCRYPTION_KEY=sua_chave_de_criptografia_32_chars

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx-xxxxxx
MP_WEBHOOK_URL=https://seu-backend.com/api/webhooks/mercadopago

# WhatsApp Integration (Evolution API)
WHATSAPP_PROVIDER=evolution
WHATSAPP_BASE_URL=https://sua-instancia-evolution.com
WHATSAPP_INSTANCE=restaurante-acai
WHATSAPP_API_KEY=sua_api_key

# Firebase Admin (backend, opcional fora do staging/prod)
# Preferencial no Render: cole o JSON completo da service account em uma unica variavel
FIREBASE_SERVICE_ACCOUNT_JSON=
# Alternativa: preencher o trio abaixo
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=https://seu-backend.com
