# Infraestrutura Geral
PORT=3000
NODE_ENV=production

# Banco de Dados (PostgreSQL recomendado)
DATABASE_URL=postgres://user:password@host:port/database

# Cache & Filas
REDIS_URL=redis://user:password@host:port

# Segurança
JWT_SECRET=sua_chave_secreta_longa_aqui
ENCRYPTION_KEY=sua_chave_de_criptografia_32_chars

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx-xxxxxx
MP_NOTIFICATION_URL=https://seu-backend.com/api/payments/mercadopago/webhook

# WhatsApp Integration (Evolution API)
EVOLUTION_API_URL=https://sua-instancia-evolution.com
EVOLUTION_API_KEY=sua_api_key

# Frontend
NEXT_PUBLIC_API_URL=https://seu-backend.com
